# =============================================================================
# Environment Configuration for MCP Servers
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Required: GitHub MCP Server
# -----------------------------------------------------------------------------
# GitHub Personal Access Token for GitHub MCP Server
# Required scope: repo, read:org, workflow
# Get your token at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_your_token_here

# -----------------------------------------------------------------------------
# Optional: Finance MCP Server
# -----------------------------------------------------------------------------
# Yahoo Finance API key (optional - for premium features)
# Free tier works without an API key
YF_API_KEY=

# -----------------------------------------------------------------------------
# Required: Communication Bridge API Keys
# -----------------------------------------------------------------------------
# STT_API_KEY: OpenAI API key for speech-to-text ( Whisper )
# Get your key at: https://platform.openai.com/api-keys
STT_API_KEY=

# TTS_API_KEY: ElevenLabs API key for text-to-speech
# Get your key at: https://elevenlabs.io/
TTS_API_KEY=

# VLM_API_KEY: OpenAI or Anthropic API key for vision-language models
# Get your key at: https://platform.openai.com/api-keys (GPT-4V)
# or https://console.anthropic.com/ (Claude Vision)
VLM_API_KEY=

# -----------------------------------------------------------------------------
# Optional: Override Default Endpoints
# -----------------------------------------------------------------------------
# These override the default MCP server endpoints
# MCP_FINANCE_ENDPOINT=http://localhost:3000
# MCP_GITHUB_ENDPOINT=http://localhost:3001
