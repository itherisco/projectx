{
  "build": {
    "beforeBuildCommand": "wasm-pack build --target web",
    "beforeDevCommand": "wasm-pack build --target web",
    "devPath": "../",
    "distDir": "../pkg",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "ITHERIS Console",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "window": {
        "all": true
      },
      "dialog": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "io.itheris.console",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "resources": [],
      "externalBin": [],
      "copyright": "Copyright 2026 ITHERIS Team",
      "category": "DeveloperTool",
      "shortDescription": "ITHERIS Full OS Interface - Management Console",
      "longDescription": "A bare-metal Type-1 hypervisor management console built with Leptos for reactive WebAssembly-based UI.",
      "deb": {
        "depends": []
      },
      "macOS": {
        "frameworks": [],
        "minimumSystemVersion": "",
        "exceptionDomain": "",
        "signingIdentity": null,
        "providerShortName": null,
        "entitlements": null
      },
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": ""
      }
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "ITHERIS Console - ProjectX Jarvis",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "decorations": true,
        "transparent": false,
        "focus": true
      }
    ]
  }
}
